                    exit 1
                fi
            ;;
            "user-scripts")
                if ! remove_setup_user_scripts
                then
                    printf "\n\e[31m%s\e[0m\n" \
                        "[!] Failed to remove setup: user-scripts"
                fi
            ;;
            "qemu")
                if ! remove_setup_qemu
                then
                    printf "\n\e[31m%s\e[0m\n" \
                        "[!] Failed to remove setup: qemu"
                fi
            ;;
            "gaming")
                if ! remove_setup_gaming
                then
                    printf "\n\e[31m%s\e[0m\n" \
                        "[!] Failed to remove setup: gaming"
                fi
            ;;
            "security")
                if ! remove_setup_security
                then
                    printf "\n\e[31m%s\e[0m\n" \
                        "[!] Failed to remove setup: security"
                fi
            ;;
            "audio")
                if ! remove_setup_audio
                then
                    printf "\n\e[31m%s\e[0m\n" \
                        "[!] Failed to remove setup: audio"
                fi
            ;;
            "bluetooth")
                if ! remove_setup_bluetooth
                then
                    printf "\n\e[31m%s\e[0m\n" \
                        "[!] Failed to remove setup: bluetooth"
                fi
            ;;
            "media")
                if ! remove_setup_media
                then
                    printf "\n\e[31m%s\e[0m\n" \
                        "[!] Failed to remove setup: media"
                fi
            ;;
            "embedded-rust")
                if ! remove_setup_embedded_rust
                then
                    printf "\n\e[31m%s\e[0m\n" \
                        "[!] Failed to remove setup: embedded-rust"
                fi
            ;;
            "rust-dioxus")
                if ! remove_setup_rust_dioxus
                then
                    printf "\n\e[31m%s\e[0m\n" \
                        "[!] Failed to remove setup: rust-dioxus"
                fi
            ;;
            "3d-printing")
                if ! remove_setup_3d_printing
                then
                    printf "\n\e[31m%s\e[0m\n" \
                        "[!] Failed to remove setup: 3d-printing"
                fi
            ;;
            "gnome")
                if ! remove_setup_gnome
                then
                    printf "\n\e[31m%s\e[0m\n" \
                        "[!] Failed to remove setup: gnome"
                fi
            ;;
            *)
                printf "\n\e[31m%s %s\e[0m\n" \
                    "[!] Chosen setup did not match remove setup case statement." \
                    "This shouldn't happen...stopping"
                exit 1
            ;;
        esac
    done
}

case $1 in
    "add-please-to-path")          add_please_to_path;exit 0;;
    "add-user-scripts-to-path")    add_user_scripts_to_path;exit 0;;
esac


cd $linux_setup_directory
check_library_files_exist

case $1 in
    "install")
        check_packages || exit $?
        install ${@:2}
        cd $linux_setup_directory
        bash $CONFIG_INSTALL_SCRIPT
    ;;
    "uninstall")
        check_packages || exit $?
        uninstall ${@:2}
        cd $linux_setup_directory
        bash $CONFIG_INSTALL_SCRIPT
    ;;
    "setup")
        check_packages || exit $?
        setup ${@:2}
        cd $linux_setup_directory
        bash $CONFIG_INSTALL_SCRIPT
    ;;
    "remove-setup")
        check_packages || exit $?
        remove_setup ${@:2}
        cd $linux_setup_directory
        bash $CONFIG_INSTALL_SCRIPT
    ;;
    "add-configs")
        check_packages || exit $?
        bash $CONFIG_INSTALL_SCRIPT
    ;;
    "version"|"--version") echo "0.1.0";;
    "--help"|"-h"|"") display_help;;
    *) 
        printf "\n\e[31m%s\e[0m %s\n" "[Error]" \
            "Invalid use of the \`$SCRIPT_NAME\` command"
        display_help
        exit 1
        ;;
esac
