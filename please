    for setup_name in ${setups_chosen[@]}
    do
        if ! echo "${SETUP_OPTIONS[*]}" | grep "$setup_name" &>/dev/null
        then
            printf "\n\n\e[31m%s\n\t%s\e[0m\n" \
                "[!] '$setup_name' is not a supported setup" \
                " - TIP: run \`$SCRIPT_NAME setup --list\` to see supported setups"
            exit 2
