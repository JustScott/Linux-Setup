setup() {
    local \
        setups_chosen \
        FLAG_list_packages

    for arg in $@
    do
        case $arg in
            "-l" | "--list")
                [[ -n "$FLAG_list_packages" ]] && {
                    printf "\n\e[31m%s\e[0m\n" \
                        "[!] duplicated the list setups flag"
                    exit 1
                }
                FLAG_list_setups=1
            ;;
            *)
                # Support flags starting with '-' or "--" shouldn't reach
                # the catchall case
                if [[ $arg =~ ^-{1,2} ]]
                then
                    printf "\n\e[31m%s\e[0m\n" \
                        "[!] The '$arg' flag isn't supported"
                    exit 1
                fi
                setups_chosen+=($arg)
            ;;
        esac
    done

    if ((FLAG_list_setups))
    then
        printf "\nAvailable Setup Options:\n"
        for setup_name in ${SETUP_OPTIONS[@]}
        do
            echo "  - $setup_name"
        done
        echo ""

        if [[ -n $setups_chosen ]]
        then
            printf "\n\e[31m%s %s\e[0m\n" \
                "[!] Cannot list setup options and" \
                "set them up in the same command"
        fi

        exit 0
