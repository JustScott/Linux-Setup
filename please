PROJECT_NAME="Linux-Setup"
SCRIPT_NAME="please"

REQUIRED_PACKAGES=(
    which bash grep cat rfkill uname
    usermod gpasswd groups groupadd groupdel
)

PRETTY_OUTPUT_LIBRARY="${linux_setup_directory}/GeneralLibraries/pretty_output_library.sh"

if ! source "$PRETTY_OUTPUT_LIBRARY" &>/dev/null
then
    printf "\n\e[31m%s\e[0m %s\n" "[Error]" \
        "Couldn't source '$PRETTY_OUTPUT_LIBRARY', this shouldn't happen. Stopping."
    exit 1
fi

ARCH_SYSTEM=0
DEBIAN_SYSTEM=0

if command -v pacman &>/dev/null
then
    ARCH_SYSTEM=1
    DEBIAN_SYSTEM=0
elif command -v apt-get &>/dev/null
then
    DEBIAN_SYSTEM=1
    ARCH_SYSTEM=0
else
    printf "\n\e[31m%s\e[0m%s %s\n" "[Error]" \
        "No package manager detected. Only pacman and apt-get are" \
        "supported. Stopping."
    exit 1
fi

INSTALLABLE_PACKAGES=(
    qutebrowser rust python flatpak
)
SETUP_OPTIONS=(
    base_packages host_packages media gnome qemu
)

if ((ARCH_SYSTEM))
then
    INSTALLABLE_PACKAGES+=(
        yay docker
    )
    SETUP_OPTIONS+=(
        security audio bluetooth
        gaming 3d-printing embedded-rust rust-dioxus
    )

    PACKAGE_INSTALLATION_LIBRARY=./ArchLibraries/package_installation_library.sh
    SETUP_INSTALLATION_LIBRARY=./ArchLibraries/setup_installation_library.sh
elif ((DEBIAN_SYSTEM))
then
    INSTALLABLE_PACKAGES+=(
        librewolf
    )

    PACKAGE_INSTALLATION_LIBRARY=./DebianLibraries/package_installation_library.sh
    SETUP_INSTALLATION_LIBRARY=./DebianLibraries/setup_installation_library.sh
else
    printf "\n\e[31m%s\e[0m%s\n" "[Error]" \
        "Distro not detected properly, this shouldn't happen. Stopping."
    exit 1
fi

PRETTY_OUTPUT_LIBRARY=./GeneralLibraries/pretty_output_library.sh

CONFIG_INSTALL_SCRIPT=./install_configurations.sh

if ! echo "$@" | grep "add-please-to-path" &>/dev/null
then
    if ! [[ -d "$linux_setup_directory" ]]
    then
        printf "\n\e[31m%s\n%s\n%s\e[0m\n" \
            "[!] '\$linux_setup_directory' variable not set, or not set to" \
            "    the correct directory path. Either way, \`cd\` into the" \
            "    '$PROJECT_NAME' directory and run \`$SCRIPT_NAME add-please-to-path\`."
        exit $4
    fi
fi

add_please_to_path() {
    if [[ $(basename $(pwd)) == "$PROJECT_NAME" ]]
    then
        bashrc_line="export linux_setup_directory=\"$(pwd)\""

        if ! [[ -f "${HOME}/.bashrc" ]]
        then
            if touch "${HOME}/.bashrc" &>/dev/null
            then
                printf "\n\e[32m%s\e[0m\n" \
                    "Created the file ${HOME}/.bashrc"
            else
                printf "\n\e[31m%s\n%s\n%s\e[0m\n" \
                    "[!] Your user doesn't have a .bashrc in there \$HOME" \
                    "    directory, and attempts at creating one failed. A" \
                    "    ${HOME}/.bashrc file is required for this script."
                exit 7
            fi
        fi

        if grep "export linux_setup_directory=\"" "${HOME}/.bashrc" \
            | grep "/$PROJECT_NAME\"$" &>/dev/null
        then
            sed -i \
                "/^export linux_setup_directory=\".*/c\\${bashrc_line}" \
                "${HOME}/.bashrc"
        else
            echo -e "\n$bashrc_line" >> "${HOME}/.bashrc"
        fi

        # Check that the line was added without issue
        if grep "$bashrc_line" "${HOME}/.bashrc" &>/dev/null
        then
            printf "\n\e[32m%s\e[0m\n" \
                "Added '$PROJECT_NAME' directory path to '.bashrc'"
        else
            printf "\n\e[31m%s\n%s\e[0m\n" \
                "[!] Could not add '$PROJECT_NAME' directory to your" \
                "    '.bashrc'... Check the files permissions and try again"
            exit 7
        fi

        # Create a .bin directory in $HOME for the script
        if ! [[ -f "./${SCRIPT_NAME}" ]]
        then
            printf "\n\e[31m%s\n%s\e[0m\n" \
                "[!] './${SCRIPT_NAME}' not found. Move to the '$PROJECT_NAME'" \
                "    directory containing the '$SCRIPT_NAME' script and try again"
            exit 8
        fi

        chmod u+x "./${SCRIPT_NAME}"

        if ! [[ -d "${HOME}/.bin" ]]
        then
            if mkdir -p "${HOME}/.bin" &>/dev/null
            then
                printf "\n\e[32m%s\e[0m" "Created ${HOME}/.bin"
            else
                printf "\n\e[31m%s\e[0m\n" "[!] Failed to create ${HOME}/.bin"
                exit 7
            fi
        fi

        if ! cat "${HOME}/.bin/${SCRIPT_NAME}" &>/dev/null
        then
            if ln -sf "$(pwd)/${SCRIPT_NAME}" "${HOME}/.bin/" &>/dev/null
            then
                printf "\n\e[32m%s\e[0m\n" \
                    "Created softlink to '$SCRIPT_NAME' in ${HOME}/.bin"
            else
                printf "\n\e[31m%s\e[0m\n" \
                    "[!] Failed to create softlink to '$SCRIPT_NAME' in ${HOME}/.bin"
                exit 7
            fi
        fi

        path_modification="export PATH=\"\$PATH:\$HOME/.bin\""

        if ! grep "^$path_modification$" "${HOME}/.bashrc" &>/dev/null
        then
            echo -e "\n$path_modification" >> "${HOME}/.bashrc"
        fi

        # Check that the line was added without issue
        if ! grep "$path_modification" "${HOME}/.bashrc" &>/dev/null
        then
            printf "\n\e[31m%s\n%s\e[0m\n" \
                "[!] Could not edit path in '${HOME}/.bashrc'..." \
                "    Check the files permissions and try again"
            exit 7
        fi
    else
        printf "\n\e[31m%s %s\e[0m\n" \
            "[!] Must be in the $PROJECT_NAME directory to" \
            "add it's path to your .bashrc"
        exit 1
    fi
}

add_user_scripts_to_path()
{
    if ! [[ -d "$linux_setup_directory" ]]
    then
        printf "\n\e[31m%s\n%s\n%s\e[0m\n" \
            "[!] '\$linux_setup_directory' variable not set, or not set to" \
            "    the correct directory path. Either way, \`cd\` into the" \
            "    '$PROJECT_NAME' directory and run \`$SCRIPT_NAME add-please-to-path\`."
        exit $4
    fi

    scripts_dir="$linux_setup_directory/ScriptsAddedToPath"
    bashrc_line="export PATH=\"\$PATH:$scripts_dir\""

    if ! grep "$bashrc_line" ${HOME}/.bashrc &>/dev/null
    then
        echo -e "\n$bashrc_line" >> ${HOME}/.bashrc 2>>"$STDERR_LOG_PATH" &
        task_output $! "$STDERR_LOG_PATH" \
            "Add the user scripts directory to \$PATH in .bashrc"
        [[ $? -ne 0 ]] && return 1
    fi

    return 0
}

check_library_files_exist() {
    if ! [[ -f "$PRETTY_OUTPUT_LIBRARY" ]]
    then
        printf "\n\e[31m%s\e[0m\n" \
            "[!] Missing pretty output script. Cannot Proceed"
        exit 4
    fi
    if ! [[ -f "$PACKAGE_INSTALLATION_LIBRARY" ]]
    then
        printf "\n\e[31m%s\e[0m\n" \
            "[!] Missing package installation scripts. Cannot Proceed"
        exit 4
    fi
    if ! [[ -f "$SETUP_INSTALLATION_LIBRARY" ]]
    then
        printf "\n\e[31m%s\e[0m\n" \
            "[!] Missing setup installation scripts. Cannot Proceed"
        exit 4
    fi
}

check_packages()
{
    for tool in ${REQUIRED_PACKAGES[@]}
    do
        if ! command -v $tool &>/dev/null
        then
            if ! sudo -n true &>/dev/null
            then
                printf "\n\e[36m%s\e[0m\n" \
                    "sudo is needed to ensure required packages are installed..."
            fi
            sudo -v || return 1
            if ! sudo which $tool &>/dev/null
            then
                printf "\n\e[31m%s\e[0m\n" "[!] Must install '$tool' for $SCRIPT_NAME to work"
                tools_not_installed=1
            fi
        fi
    done

    if ((tools_not_installed))
    then
        return 6
    fi
}

