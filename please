        printf "\n\e[31m%s\n%s\e[0m\n" \
            "[!] Issue sourcing setup library despite passing" \
            "    library file checks... This shouldn't happen"
    fi

    for setup_name in ${setups_chosen[@]}
    do
        case $setup_name in
            "base_packages")
                if ! remove_setup_base_packages
                then
                    printf "\n\e[31m%s\e[0m\n" \
                        "[!] Failed to remove setup: base_packages"
                    exit 1
                fi
            ;;
            "host_packages")
                if ! remove_setup_host_packages
                then
